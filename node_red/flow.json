        "group": "dashboard_group1",
        "name": "Dashboard Theme & Title Modifier",
        "order": 0,
        "width": 0,
        "height": 0,
        "format": "<style>\n    /* Make the toolbar look premium */\n    md-toolbar {\n        background: linear-gradient(90deg, #1e3c72 0%, #2a5298 100%) !important;\n    }\n    \n    /* Hide the default title and inject the custom one */\n    .md-toolbar-tools h1.ng-binding {\n        visibility: hidden;\n        position: relative;\n    }\n    .md-toolbar-tools h1.ng-binding::after {\n        content: '\ud83c\udfd9\ufe0f Smart Waste Management System for Metropolitan Cities';\n        visibility: visible;\n        position: absolute;\n        left: 0;\n        top: 0;\n        font-size: 22px !important;\n        font-weight: bold !important;\n        width: 800px;\n    }\n</style>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resizes": true,
        "templateScope": "local",
        "x": 620,
