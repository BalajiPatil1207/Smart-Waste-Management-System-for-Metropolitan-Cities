    {
        "id": "dummy_gen",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Generate Stable Bin Data",
        "func": "let bin1 = {\n    payload: {\n        Bin_ID: \"BIN001\",\n        Latitude: 28.6139 + (Math.random() * 0.002 - 0.001),\n        Longitude: 77.2090 + (Math.random() * 0.002 - 0.001),\n        Fill_Level: Math.floor(Math.random() * 15) + 60, // Stable around 60-75%\n        Temperature: Math.floor(Math.random() * 5) + 30, // Stable around 30-35 C\n        Battery_Level: 85, // Stable battery\n        Methane_PPM: Math.floor(Math.random() * 50) + 100, // Stable Odor\n        Timestamp: new Date().toISOString()\n    }\n};\n\nreturn bin1;",
        "outputs": 1,
        "noerr": 0,
        "x": 150,
        "y": 320,
        "wires": [
            [
                "3"
            ]
        ]
