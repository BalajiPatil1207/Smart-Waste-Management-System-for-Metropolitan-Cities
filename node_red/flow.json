    {
        "id": "ibm_iot_broker",
        "type": "mqtt-broker",
        "name": "IBM Watson IoT",
        "broker": "YOUR_ORG_ID.messaging.internetofthings.ibmcloud.com",
        "port": "1883",
        "clientid": "a:YOUR_ORG_ID:SmartWasteApp",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true,
        "autoUnsubscribe": true,
        "userProps": "",
        "sessionExpiry": ""
    },
    {
        "id": "3",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Process Bin Data",
        "func": "let data = msg.payload;\n\nlet status = \"Normal\";\nif(data.Fill_Level > 80) {\n    status = \"Critical Full\";\n} else if(data.Methane_PPM > 350) {\n    status = \"Toxic Odor\";\n} else if(data.Battery_Level < 20) {\n    status = \"Low Battery\";\n} else if(data.Fill_Level > 50) {\n    status = \"Moderate\";\n} else {\n    status = \"Empty\";\n}\ndata.Status = status;\nmsg.payload = data;\nmsg.topic = data.Bin_ID;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 350,
        "y": 200,
        "wires": [
            [
                "6",
                "7",
                "battery_gauge",
                "gas_gauge",
                "11",
                "filter_level",
                "filter_temp",
                "10"
            ]
        ]
    },
