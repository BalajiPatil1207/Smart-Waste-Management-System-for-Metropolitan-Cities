        "func": "let data = msg.payload;\nif (!data || !data.Bin_ID) {\n    msg.payload = { success: false, error: \"Missing Bin_ID\" };\n    msg.statusCode = 400;\n    return msg;\n}\n\nlet fill = Number(data.Fill_Level !== undefined ? data.Fill_Level : 0);\nlet gas = Number(data.Methane_PPM !== undefined ? data.Methane_PPM : 0);\nlet bat = Number(data.Battery_Level !== undefined ? data.Battery_Level : 100);\nlet temp = Number(data.Temperature !== undefined ? data.Temperature : 25);\nlet humid = Number(data.Humidity !== undefined ? data.Humidity : 50);\nlet lid = data.Lid_Status !== undefined ? data.Lid_Status : \"CLOSED\";\nlet solar = Number(data.Solar_Charge !== undefined ? data.Solar_Charge : 0);\n\nlet bins_info = {\n    \"BIN001\": {lat: 28.6139, lon: 77.2090},\n    \"BIN002\": {lat: 28.6230, lon: 77.2150},\n    \"BIN003\": {lat: 28.6050, lon: 77.1950}\n};\n\nlet bin_info = bins_info[data.Bin_ID] || {lat: 28.6100, lon: 77.2000};\n\nlet status = \"Normal\";\nif(fill >= 95) status = \"Critical Full\";\nelse if(gas > 350) status = \"Toxic Odor\";\nelse if(bat < 20) status = \"Low Battery\";\nelse if(fill > 50) status = \"Moderate\";\nelse status = \"Empty\";\n\nlet newData = {\n    Bin_ID: data.Bin_ID,\n    Latitude: bin_info.lat,\n    Longitude: bin_info.lon,\n    Fill_Level: fill,\n    Temperature: temp,\n    Humidity: humid,\n    Battery_Level: bat,\n    Methane_PPM: gas,\n    Lid_Status: lid,\n    Solar_Charge: solar,\n    Timestamp: new Date().toISOString(),\n    Status: status\n};\n\nlet fleet = global.get('fleetData') || {};\nfleet[data.Bin_ID] = newData;\nglobal.set('fleetData', fleet);\n\nmsg.payload = { success: true, data: newData };\nreturn [msg, { payload: newData }];",
