    {
        "id": "3",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Process Bin Data",
        "func": "let data = msg.payload;\n\nlet status = \"Normal\";\nif(data.Fill_Level > 80) {\n    status = \"Critical Full\";\n} else if(data.Methane_PPM > 350) {\n    status = \"Toxic Odor!\";\n} else if(data.Battery_Level < 20) {\n    status = \"Low Battery\";\n} else if(data.Fill_Level > 50) {\n    status = \"Moderate\";\n} else {\n    status = \"Normal (Empty)\";\n}\ndata.Status = status;\nmsg.payload = data;\nmsg.topic = data.Bin_ID;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 350,
        "y": 200,
        "wires": [
            [
                "4",
                "6",
                "7",
                "battery_gauge",
                "gas_gauge",
                "9",
                "10",
                "11",
                "filter_level",
                "filter_temp",
                "bar_chart_filter"
            ]
        ]
    },
    {
        "id": "4",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Format for Cloudant",
        "func": "msg.payload = {\n    Bin_ID: msg.payload.Bin_ID,\n    Latitude: msg.payload.Latitude,\n    Longitude: msg.payload.Longitude,\n    Fill_Level: msg.payload.Fill_Level,\n    Temperature: msg.payload.Temperature,\n    Methane_PPM: msg.payload.Methane_PPM,\n    Battery_Level: msg.payload.Battery_Level,\n    Timestamp: msg.payload.Timestamp,\n    Status: msg.payload.Status\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 580,
        "y": 80,
        "wires": [
            [
                "5"
            ]
        ]
    },
