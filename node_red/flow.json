    {
        "id": "dummy_gen",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Generate Multi-Bin Data",
        "func": "let bin1 = {\n    payload: {\n        Bin_ID: \"BIN001\",\n        Latitude: 28.6139 + (Math.random() * 0.02 - 0.01),\n        Longitude: 77.2090 + (Math.random() * 0.02 - 0.01),\n        Fill_Level: Math.floor(Math.random() * 100),\n        Temperature: Math.floor(Math.random() * 15) + 30,\n        Battery_Level: Math.floor(Math.random() * 40) + 60, // 60-100%\n        Methane_PPM: Math.floor(Math.random() * 200) + 50,\n        Timestamp: new Date().toISOString()\n    }\n};\n\nlet bin2 = {\n    payload: {\n        Bin_ID: \"BIN002\",\n        Latitude: 28.5355 + (Math.random() * 0.02 - 0.01),\n        Longitude: 77.2410 + (Math.random() * 0.02 - 0.01),\n        Fill_Level: Math.floor(Math.random() * 100),\n        Temperature: Math.floor(Math.random() * 15) + 25,\n        Battery_Level: Math.floor(Math.random() * 30) + 10, // 10-40%\n        Methane_PPM: Math.floor(Math.random() * 300) + 150,\n        Timestamp: new Date().toISOString()\n    }\n};\n\nlet bin3 = {\n    payload: {\n        Bin_ID: \"BIN003\",\n        Latitude: 28.7041 + (Math.random() * 0.02 - 0.01),\n        Longitude: 77.1025 + (Math.random() * 0.02 - 0.01),\n        Fill_Level: Math.floor(Math.random() * 100),\n        Temperature: Math.floor(Math.random() * 15) + 28,\n        Battery_Level: Math.floor(Math.random() * 50) + 50, // 50-100%\n        Methane_PPM: Math.floor(Math.random() * 100) + 20,\n        Timestamp: new Date().toISOString()\n    }\n};\n\n// Send all 3 bin data simultaneously\nreturn [[bin1, bin2, bin3]];",
        "outputs": 1,
        "noerr": 0,
        "x": 150,
        "y": 320,
        "wires": [
            [
                "2",
                "3"
            ]
        ]
