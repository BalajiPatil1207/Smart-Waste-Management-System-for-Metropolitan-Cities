    {
        "id": "10",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Map Marker Formatting",
        "func": "let p = msg.payload;\nmsg.payload = {\n    name: \"Smart Bin 001\",\n    lat: p.Latitude,\n    lon: p.Longitude,\n    icon: \"trash\",\n    iconColor: p.Fill_Level > 80 ? \"red\" : (p.Fill_Level > 50 ? \"orange\" : \"green\"),\n    extrainfo: `<b>Bin ID:</b> ${p.Bin_ID} <br/> <b>Fill Level:</b> ${p.Fill_Level}% <br/> <b>Temp:</b> ${p.Temperature}°C <br/> <b>Battery:</b> ${p.Battery_Level}% <br/> <b>Gas:</b> ${p.Methane_PPM} PPM <br/> <b>Status:</b> ${p.Status}`\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 600,
        "y": 560,
        "wires": [
