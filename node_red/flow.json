        "format": "<script>\n    setTimeout(function() {\n        // Change Top Bar Title\n        var toolbarTitle = document.querySelector('md-toolbar .md-toolbar-tools h1');\n        if(toolbarTitle) {\n            toolbarTitle.innerHTML = '🏙️ Smart Waste Management System for Metropolitan Cities';\n        }\n    }, 500);\n</script>\n<style>\n    /* Make the toolbar look premium */\n    md-toolbar {\n        background: linear-gradient(90deg, #1e3c72 0%, #2a5298 100%) !important;\n    }\n    .md-toolbar-tools h1 {\n        font-size: 22px !important;\n        font-weight: bold !important;\n    }\n</style>",
